# 📱 EDUAI - MOBILE APP (EXPO) ENVIRONMENT VARIABLES
# Copy this to .env and fill in the missing values

# Supabase Configuration
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Backend API Configuration
# Local Development: http://192.168.1.10:3000 (Replace with your machine's IP)
EXPO_PUBLIC_BACKEND_URL=http://localhost:3000

# -----------------------------------------------------------------------------

# 🖥️ EDUAI - BACKEND (EXPRESS) ENVIRONMENT VARIABLES
# Copy this to backend/.env and fill in the missing values

# Server Configuration
PORT=3000

# Supabase Configuration (Service/Anon Key)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# AI Provider Keys (Groq) - Rotating Keys
GROQ_API_KEY_1=gsk_...
GROQ_API_KEY_2=gsk_...
GROQ_API_KEY_3=gsk_...

# OCR Provider Key (OCR.Space)
OCR_API_KEY=your-ocr-space-api-key
