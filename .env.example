# EDUAI - Production Environment Configuration Template
# Duplicate this file to .env and fill in the values

# --- API KEYS (Used by AIService.ts) ---
# Groq keys for AI processing (Rotation fallback supported)
EXPO_PUBLIC_GROQ_API_KEY_1=your_groq_key_here
EXPO_PUBLIC_GROQ_API_KEY_2=
EXPO_PUBLIC_GROQ_API_KEY_3=

# Anthropic keys for heavy OCR or specific tasks
EXPO_PUBLIC_CLAUDE_API_KEY=

# --- OCR CONFIG (Used by OCRService.ts) ---
# OCR.space API key (Fast alternative)
EXPO_PUBLIC_OCR_KEY=helloworld

# --- SUPABASE CONFIG ---
EXPO_PUBLIC_SUPABASE_URL=your_supabase_project_url
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
