# EDUAI - Production Environment Configuration Template
# Duplicate this file to .env and fill in the values

# --- BACKEND PROXY (REQUIRED) ---
# The URL of your deployed Express backend (e.g., https://your-backend.railway.app)
EXPO_PUBLIC_BACKEND_URL=http://localhost:3000
# The shared secret token (must match APP_TOKEN on the backend)
EXPO_PUBLIC_APP_TOKEN=your_secure_shared_secret_here

# --- SUPABASE CONFIG ---
EXPO_PUBLIC_SUPABASE_URL=your_supabase_project_url
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
