# 🌐 SERVER
PORT=3000

# 🔐 AUTHENTICATION (SUPABASE)
# Used to verify JWT tokens from the mobile app
SUPABASE_URL=https://your-project-url.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# 🤖 GROQ KEYS (Add as many as you have for rotation)
GROQ_API_KEY_1=gsk_...
GROQ_API_KEY_2=gsk_...
GROQ_API_KEY_3=gsk_...
# Bulk keys (comma separated)
GROQ_API_KEYS=gsk_...,gsk_...

# 📄 OCR.SPACE KEYS
OCR_API_KEY=your-ocr-space-key
